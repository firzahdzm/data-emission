# Reverse proxy + Basic Auth for the emission tracker.
# /etc/nginx/sites-available/emission-tracker  →  symlink to sites-enabled
#
# 1. Generate basic auth file:
#      sudo apt install apache2-utils
#      sudo htpasswd -c /etc/nginx/.htpasswd_emission YOUR_USERNAME
# 2. Issue cert:
#      sudo certbot --nginx -d emission.example.com
# 3. sudo systemctl reload nginx

server {
    listen 80;
    server_name emission.example.com;
    # certbot will rewrite this to redirect to HTTPS automatically.

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name emission.example.com;

    ssl_certificate     /etc/letsencrypt/live/emission.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/emission.example.com/privkey.pem;

    # Basic auth — the app itself has no login
    auth_basic           "Gradient Emission Tracker";
    auth_basic_user_file /etc/nginx/.htpasswd_emission;

    # Hide nginx version
    server_tokens off;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Forward the basic-auth username to the app. The app uses this to
        # gate admin-only endpoints (settle/unsettle) against the
        # AppConfig.admin_users list.
        proxy_set_header X-Remote-User     $remote_user;

        # The dashboard auto-refreshes every 5 minutes; long polling not used.
        proxy_read_timeout  60s;
        proxy_send_timeout  60s;
    }

    # Allow Let's Encrypt renewal even with basic auth enabled
    location /.well-known/acme-challenge/ {
        auth_basic off;
        root /var/www/html;
    }
}
